<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileApp.Views.StudentRegistrationPage"
             Title="Student Registration">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">
            <Entry x:Name="NameEntry" Placeholder="Student Name" />
            <Entry x:Name="RoomEntry" Placeholder="Room Number" />
            <Entry x:Name="NfcEntry" Placeholder="NFC Card ID" />
            <Entry x:Name="BioEntry" Placeholder="Biometric ID" />
            <Button Text="Register" Clicked="OnRegisterClicked" />
            <Label x:Name="StatusLabel"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
