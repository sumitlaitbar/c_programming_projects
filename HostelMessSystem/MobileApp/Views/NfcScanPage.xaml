<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileApp.Views.NfcScanPage"
             Title="NFC Scan">
    <VerticalStackLayout Padding="20" Spacing="10">
        <Label Text="Scan NFC Card" FontAttributes="Bold"/>
        <Entry x:Name="NfcIdEntry" Placeholder="NFC Card ID" />
        <Button Text="Mark Attendance" Clicked="OnMarkNfc" />
        <Label x:Name="ResultLabel" />
    </VerticalStackLayout>
</ContentPage>
